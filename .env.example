# TG Text Game Assistant example environment
# 复制本文件为 .env 后，再填入你自己的真实值。

# --- Web / app ---
TG_GAME_DEBUG=0
TG_GAME_HOST=127.0.0.1
TG_GAME_PORT=8787
TG_GAME_DOMAIN=
TG_GAME_SSL_CERTFILE=
TG_GAME_SSL_KEYFILE=

# --- Telegram 登录（必填） ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TG_GAME_SESSION_NAME=tg_game
TG_GAME_LOGIN_SESSION_NAME=tg_game_login

# --- 绑定目标群 / Bot（完整启用自动任务时必填） ---
TG_GAME_BOUND_CHAT_ID=
# 目标群开启 topic 时填写 thread id；普通群可留空
TG_GAME_BOUND_THREAD_ID=
TG_GAME_BOUND_CHAT_TYPE=group
# 洞府公共入口消息未找到时优先使用；只接受 t.me/telegram.me + startapp=df_*
TG_GAME_ESTATE_MINIAPP_FALLBACK_URL=
# 兼容旧配置；未配置完整 URL 时使用默认 Bot + 有效 df_*
TG_GAME_ESTATE_MINIAPP_FALLBACK_START_PARAM=
TG_GAME_BOUND_BOT_ID=
TG_GAME_ALLOWED_BOT_IDS=

# --- 外部账号 / 保活 ---
TG_GAME_EXTERNAL_KEEPALIVE_SECONDS=900
TG_GAME_EXTERNAL_KEEPALIVE_POLL_SECONDS=600
TG_GAME_LOG_MESSAGES=0

# --- 管理员 ---
AUTHORIZED_USER_ID=

# --- 自动任务默认值 ---
# 凡人修仙自动闭关 / 宗门自动任务的默认指令、间隔和时间点已在代码逻辑里固定
